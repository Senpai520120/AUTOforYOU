# AUTOforYOU — переменные окружения (скопируй в .env и заполни)
# -----------------------------------------------------------------------
# ДЛЯ ЛОКАЛЬНОЙ РАЗРАБОТКИ: можно оставить только DEBUG=true и SECRET_KEY.
# Остальное подключается по необходимости.
# -----------------------------------------------------------------------

# ─── Django ──────────────────────────────────────────────────────────────────
# Обязательно сгенерировать новый ключ для продакшена:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-django-secret-key-here

# true — режим разработки (подробные ошибки, ALLOWED_HOSTS=*)
# false — продакшен (обязательно для деплоя)
DEBUG=true

# Хосты через запятую. При DEBUG=true можно не задавать.
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ─── База данных ─────────────────────────────────────────────────────────────
# НЕ ЗАДАН → работает SQLite (локальная разработка, ничего не нужно устанавливать)
# ЗАДАН   → PostgreSQL (или другой провайдер)
# Формат: postgres://ИМЯ_ПОЛЬЗОВАТЕЛЯ:ПАРОЛЬ@ХОСТ:ПОРТ/ИМЯ_БАЗЫ
# DATABASE_URL=postgres://autoforyou:strongpassword@localhost:5432/autoforyou_db

# ─── S3-хранилище фото ───────────────────────────────────────────────────────
# НЕ ЗАДАНЫ → фото хранятся локально в папке media/ (для разработки)
# ЗАДАНЫ   → фото загружаются в AWS S3 (или совместимый сервис)
#
# AWS S3:
# S3_BUCKET_NAME=your-s3-bucket-name
# S3_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
#
# Cloudflare R2 (совместим с S3, дешевле):
# S3_BUCKET_NAME=your-r2-bucket
# S3_REGION=auto
# AWS_ACCESS_KEY_ID=your_r2_access_key
# AWS_SECRET_ACCESS_KEY=your_r2_secret_key
# S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com

# ─── LiqPay — платёжный шлюз ─────────────────────────────────────────────────
# Ключи из https://www.liqpay.com/en/authorization/merchant → Бизнес → Магазин
LIQPAY_PUBLIC_KEY=your_liqpay_public_key
LIQPAY_PRIVATE_KEY=your_liqpay_private_key
# true — sandbox (тестовые платежи), false — реальные платежи
LIQPAY_SANDBOX=true

# ─── VIN-интеграции ──────────────────────────────────────────────────────────
# Opendatabot — UA реестры авто. Без ключа: demo=True, не падает.
OPENDATABOT_API_KEY=your_opendatabot_api_key

# Apify — скрейпер лотов Copart/IAAI. Без токена: demo=True, не падает.
APIFY_TOKEN=your_apify_token

# ─── Email ───────────────────────────────────────────────────────────────────
# Dev-режим: письма выводятся в консоль (не задавать для локальной разработки).
# Продакшен: раскомментировать и заполнить SMTP-данные.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=your@email.com
# EMAIL_HOST_PASSWORD=your_email_password
DEFAULT_FROM_EMAIL=noreply@autoforyou.ua

# ─── Курс НБУ (бесплатно, без ключа) ─────────────────────────────────────────
# python manage.py fetch_nbu_rates --date YYYYMMDD
# Источник: bank.gov.ua/NBUStatService/v1/statdirectory/exchange
