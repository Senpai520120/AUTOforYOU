# AUTOforYOU — переменные окружения (скопируй в .env и заполни)

# Django
SECRET_KEY=your-django-secret-key-here
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1

# База данных (PostgreSQL для продакшена)
DATABASE_URL=postgres://user:password@localhost:5432/autoforyou

# LiqPay — платёжный шлюз
# Ключи из https://www.liqpay.com/en/authorization/merchant → Бизнес → Магазин
LIQPAY_PUBLIC_KEY=your_liqpay_public_key
LIQPAY_PRIVATE_KEY=your_liqpay_private_key
# true — sandbox-режим (тестовые платежи), false — продакшен
LIQPAY_SANDBOX=true

# VIN-интеграции (платные, нужен договор)
# VIN_CHECK_API_KEY=your_vincheck_key
# CARVERTICAL_API_KEY=your_carvertical_key
# BIDFAX_API_KEY=your_bidfax_key

# Opendatabot — UA реестры авто (VIN/номер → регистрации, ограничения, владельцы)
# Без ключа: провайдер возвращает demo=True, не падает.
# Получить ключ: https://opendatabot.ua
OPENDATABOT_API_KEY=your_opendatabot_api_key

# Apify — управляемый скрейпер лотов Copart/IAAI
# Без токена: ApifyLotProvider возвращает demo=True, не падает.
# Получить токен: https://apify.com
APIFY_TOKEN=your_apify_token

# Курс НБУ — бесплатно, без ключа (см. management command fetch_nbu_rates)
# NBU API: https://bank.gov.ua/NBUStatService/v1/statdirectory/exchange
